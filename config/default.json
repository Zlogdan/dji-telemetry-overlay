{
  "width": 1920,
  "height": 1080,
  "export": {
    "mode": "video",
    "output_format": "mov",
    "render_fps": 30
  },
  "performance": {
    "ffprobe_timeout": 30,
    "ffmpeg_timeout": 60,
    "png_compress_level": 1,
    "prores_qscale": 11,
    "vp9_crf": 34,
    "vp9_cpu_used": 2,
    "hw_accel": "auto",
    "render_workers": 0
  },
  "extraction": {
    "pyosmogps_frequency": 1,
    "pyosmogps_resampling_method": "lpf",
    "pyosmogps_timezone_offset": 3
  },
  "modules": [
    {
      "type": "speedometer",
      "x": 100,
      "y": 820,
      "width": 200,
      "height": 200,
      "max_speed": 150,
      "unit": "kmh",
      "enabled": true
    },
    {
      "type": "map",
      "x": 1580,
      "y": 50,
      "width": 300,
      "height": 300,
      "zoom": 14,
      "map_provider": "osm",
      "enabled": true
    },
    {
      "type": "text",
      "x": 50,
      "y": 50,
      "field": "speed",
      "label": "Скорость",
      "unit": "км/ч",
      "font_size": 36,
      "enabled": true
    },
    {
      "type": "text",
      "x": 50,
      "y": 100,
      "field": "alt",
      "label": "Высота",
      "unit": "м",
      "font_size": 36,
      "enabled": true
    },
    {
      "type": "heading",
      "x": 350,
      "y": 820,
      "width": 180,
      "height": 180,
      "enabled": true
    }
  ]
}
